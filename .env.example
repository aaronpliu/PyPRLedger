# Environment Configuration
ENV=development
DEBUG=True
LOG_LEVEL=INFO

# Database configuration
DATABASE_HOST=localhost
DATABASE_PORT=3306
DATABASE_USER=root
DATABASE_PASSWORD=
DATABASE_NAME=code_review
DATABASE_POOL_SIZE=20
DATABASE_MAX_OVERFLOW=10
DATABASE_POOL_TIMEOUT=30
DATABASE_POOL_RECYCLE=3600

# Redis configuration
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0

# CORS configuration (comma-separated list of allowed origins)
# For development with JetBrains IDE:
BACKEND_CORS_ORIGINS=http://localhost:63342,http://127.0.0.1:63342

# For production, use specific domains:
# BACKEND_CORS_ORIGINS=https://yourdomain.com,https://www.yourdomain.com

# Security configuration
SECRET_KEY=change-this-to-a-secure-random-string-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# Bitbucket API configuration
BITBUCKET_CLOUD=False
BITBUCKET_SERVER_URL=http://localhost:7990
BITBUCKET_DEFAULT_WORKSPACE=default
