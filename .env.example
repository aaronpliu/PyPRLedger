# FastAPI Pull Request Code Review System - Environment Variables
# Copy this file to .env and update the values according to your environment

# ==============================
# Project Information
# ==============================
PROJECT_NAME=PR Code Review Result Storage System
PROJECT_VERSION=1.0.0
API_V1_STR=/api/v1

# ==============================
# Environment Configuration
# ==============================
ENV=development
DEBUG=False
LOG_LEVEL=INFO

# ==============================
# Database Configuration
# ==============================
DATABASE_HOST=localhost
DATABASE_PORT=3306
DATABASE_USER=root
DATABASE_PASSWORD=your_database_password
DATABASE_NAME=code_review
DATABASE_POOL_SIZE=20
DATABASE_MAX_OVERFLOW=10
DATABASE_POOL_TIMEOUT=30
DATABASE_POOL_RECYCLE=3600

# ==============================
# Redis Configuration
# ==============================
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0
REDIS_MAX_CONNECTIONS=50

# ==============================
# Cache TTL Settings (seconds)
# ==============================
CACHE_TTL_REVIEWS=3600
CACHE_TTL_PROJECTS=21600
CACHE_TTL_USERS=43200
CACHE_TTL_STATS=3600

# ==============================
# Security Configuration
# ==============================
SECRET_KEY=change-this-to-a-random-secret-key-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# ==============================
# CORS Configuration
# ==============================
BACKEND_CORS_ORIGINS=http://localhost:3000,http://localhost:8000

# ==============================
# Rate Limit Configuration
# ==============================
RATE_LIMIT_ENABLED=True
RATE_LIMIT_MAX_REQUESTS=1000
RATE_LIMIT_PERIOD_SECONDS=60

# ==============================
# Concurrency Control Configuration
# ==============================
MAX_CONCURRENT_OPERATIONS=1000
DB_QUERY_TIMEOUT=30

# ==============================
# Prometheus Monitoring Configuration
# ==============================
PROMETHEUS_ENABLED=True
PROMETHEUS_METRICS_PATH=/metrics

# ==============================
# Pagination Defaults
# ==============================
DEFAULT_PAGE_SIZE=20
MAX_PAGE_SIZE=100

# ==============================
# Git Configuration
# ==============================
GIT_MAX_DIFF_SIZE=1048576
GIT_MAX_FILES_IN_PR=100

# ==============================
# Code Review Configuration
# ==============================
REVIEW_MIN_SCORE=0
REVIEW_MAX_SCORE=10

# ==============================
# Task Processing Configuration
# ==============================
TASK_QUEUE_ENABLED=True
MAX_RETRIES=3

# ==============================
# Bitbucket API Configuration
# ==============================
# Choose Bitbucket version: Cloud (bitbucket.org) or Server/Data Center (self-hosted)
# Set to true for Bitbucket Cloud, false for Bitbucket Server/Data Center
BITBUCKET_CLOUD=false

# Bitbucket Server/Data Center base URL (only used when BITBUCKET_CLOUD=false)
BITBUCKET_SERVER_URL=http://localhost:7990

# Bitbucket authentication credentials (username and password/app-password)
BITBUCKET_USER=admin
BITBUCKET_PASSWORD=your_password_here

# Default workspace/project key for repository lookups
BITBUCKET_DEFAULT_WORKSPACE=PROJ
