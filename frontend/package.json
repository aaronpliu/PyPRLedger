{
  "name": "frontend",
  "private": true,
  "version": "1.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:test": "vite --mode test",
    "dev:prod": "vite --mode prod",
    "build": "vue-tsc -b && vite build",
    "build:test": "vue-tsc -b && vite build --mode test",
    "build:prod": "vue-tsc -b && vite build --mode prod",
    "preview": "vite preview",
    "preview:test": "vite preview --mode test",
    "preview:prod": "vite preview --mode prod",
    "type-check": "vue-tsc --noEmit",
    "test": "vitest",
    "test:ui": "vitest --ui",
    "test:run": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui"
  },
  "dependencies": {
    "@element-plus/icons-vue": "^2.3.2",
    "@vueuse/core": "^14.2.1",
    "axios": "^1.14.0",
    "dayjs": "^1.11.20",
    "diff2html": "^3.4.56",
    "echarts": "^6.0.0",
    "element-plus": "^2.13.6",
    "jspdf": "^4.2.1",
    "jspdf-autotable": "^5.0.7",
    "md-editor-v3": "^6.4.2",
    "pinia": "^3.0.4",
    "socket.io-client": "^4.8.3",
    "vue": "^3.5.32",
    "vue-echarts": "^8.0.1",
    "vue-i18n": "^11.3.1",
    "vue-router": "^5.0.4",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@pinia/testing": "^1.0.3",
    "@playwright/test": "^1.59.1",
    "@types/node": "^24.12.2",
    "@vitejs/plugin-vue": "^6.0.5",
    "@vue/test-utils": "^2.4.6",
    "@vue/tsconfig": "^0.9.1",
    "happy-dom": "^20.8.9",
    "jsdom": "^29.0.1",
    "terser": "^5.46.1",
    "typescript": "~6.0.2",
    "vite": "^7.3.2",
    "vitest": "^4.1.2",
    "vue-tsc": "^3.2.6"
  }
}
