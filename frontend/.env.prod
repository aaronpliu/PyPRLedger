# Production Environment Configuration
# API Configuration - Point to production server
VITE_API_DOMAIN=https://api.prledger.com
VITE_API_BASE_PATH=/api/v1
VITE_API_BASE_URL=https://api.prledger.com/api/v1

# Dev Server Configuration
VITE_DEV_PORT=3001

# App Configuration
VITE_APP_TITLE=PR Ledger
VITE_APP_VERSION=2.0.0

# JWT Configuration
VITE_JWT_STORAGE_KEY=prledger_auth

# Feature Flags
VITE_ENABLE_ANALYTICS=true
VITE_ENABLE_DEBUG=false

# Security
VITE_ENABLE_HTTPS=true
